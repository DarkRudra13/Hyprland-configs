{
    "modules-left": [
        "custom/arch",
        "custom/clipboard"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "pulseaudio",
        "network",
        "idle_inhibitor"
    ],

    "custom/arch": {
        "format": "≤░μΘ",
        "tooltip": true,
        "tooltip-format": "btw"
    },

    "custom/clipboard": {
        "format": "ΎΔς",
        "tooltip": false,
        "on-click": "qdbus6 org.kde.klipper /klipper org.kde.klipper.klipper.showKlipperPopupMenu"
    },

    "cpu": {
        "interval": 2,
        "format": "ΎΜδ  {usage}%",
        "tooltip": true,
        "on-click": "plasma-systemmonitor"
    },

    "memory": {
        "interval": 5,
        "format": "≤░Ξδ  {percentage}%",
        "tooltip": true,
        "on-click": "plasma-systemmonitor"
    },

    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
        "critical-threshold": 90,
        "format": "ΎΜΚ  {temperatureC}┬░C",
        "format-critical": "ΎΜΘ  {temperatureC}┬░C"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}  {volume}%",
        "format-muted": "Ύγσ  Muted",
        "format-icons": {
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "systemsettings kcm_pulseaudio"
    },

    "network": {
        "format-wifi": "ΎΘτ  {essid} ({signalStrength}%)",
        "format-ethernet": "ΎηΨ  {ipaddr}",
        "format-disconnected": "έγι Disconnected",
        "on-click": "plasmawindowed org.kde.plasma.networkmanagement"
    },
    "bluetooth": {
   	 "format": "ΎΛΦ",
   	 "format-connected": "ΎΛΦ  {device_alias}",
   	 "format-connected-battery": "ΎΛΦ  {device_alias} {device_battery_percentage}%",
   	 "format-disabled": "≤░Γ▓",
   	 "tooltip-format": "{controller_alias}\n{controller_address}",
   	 "on-click": "systemsettings kcm_bluetooth"
     },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "custom/notification": {
    "tooltip": true,
    "format": "<span size='16pt'>{icon}</span>",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γι",
      "dnd-none": "≤░ςΥ",
      "inhibited-notification": "≤░Γδ",
      "inhibited-none": "≤░ςΣ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░ςΣ"
       },
     "return-type": "json",
     "exec-if": "which swaync-client",
     "exec": "swaync-client -swb",
     "on-click": "swaync-client -t -sw",
     "on-click-right": "swaync-client -d -sw",
     "escape": true
     },

    "clock": {
        "format": "{:%H:%M | %e %B}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    }
}
